<?xml version="1.0"?>
<odoo>

    <record id="res_config_settings_view_form_claude" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.ai.claude</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="ai.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <setting id="google_provider" position="after">
                <setting id="anthropic_provider"
                         string="Use your own Anthropic Claude account"
                         help="Provide your API key to use Claude models (Opus, Sonnet, Haiku) in AI Agents, Fields, and Server Actions"
                         groups="base.group_system">
                    <field name="anthropic_key_enabled"/>
                    <group invisible="not anthropic_key_enabled">
                        <div class="flex-grow-1">
                            <field name="anthropic_key" placeholder="sk-ant-..." password="True" nolabel="1" class="w-100"/>
                        </div>
                    </group>
                </setting>
            </setting>
        </field>
    </record>

</odoo>
