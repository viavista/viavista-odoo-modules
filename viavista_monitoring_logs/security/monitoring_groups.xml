<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_monitoring" model="ir.module.category">
        <field name="name">Monitoring</field>
        <field name="sequence">90</field>
    </record>

    <record id="res_groups_privilege_monitoring" model="res.groups.privilege">
        <field name="name">Monitoring</field>
        <field name="category_id" ref="module_category_monitoring"/>
    </record>

    <record id="group_monitoring_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="res_groups_privilege_monitoring"/>
    </record>

    <record id="group_monitoring_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="privilege_id" ref="res_groups_privilege_monitoring"/>
        <field name="implied_ids" eval="[(4, ref('group_monitoring_user'))]"/>
    </record>

</odoo>
